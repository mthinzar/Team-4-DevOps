<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= dish.name %> - FoodHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand: #e23744;
            --brand-dark: #c52d39;
            --pink-soft: #ffeef1;
        }

        body { font-family: 'Poppins', sans-serif; background: #fff; }

        .navbar-brand { color: #1a1a1a; font-weight: 800; font-size: 1.6rem; text-decoration: none; }
        .nav-link-custom { color: #1a1a1a; font-weight: 500; margin: 0 1rem; text-decoration: none; }
        .nav-link-custom:hover { color: var(--brand); }
        .brand-red { color: var(--brand); }

        .back-link { color: var(--brand); font-weight: 500; text-decoration: none; }
        .back-link:hover { color: var(--brand-dark); }

        .dish-hero {
            background: linear-gradient(120deg, #fde2e7 0%, #fcd7dd 100%);
            border-radius: 24px;
        }
        .dish-hero img {
            width: 100%;
            max-height: 320px;
            object-fit: cover;
            border-radius: 18px;
        }

        .category-badge {
            display: inline-block;
            background: var(--pink-soft);
            color: var(--brand);
            font-size: 0.72rem;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 10px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .price { color: var(--brand); font-weight: 700; font-size: 1.3rem; }
        .stars { color: #f5a623; letter-spacing: 1px; }
        .rating-summary { font-weight: 600; }

        .review-card {
            border: 1px solid #f0d0d4;
            border-radius: 14px;
            padding: 1rem 1.25rem;
            margin-bottom: 1rem;
            background: #fff;
        }
        .review-name { font-weight: 600; }
        .review-date { color: #999; font-size: 0.78rem; }
        .review-comment { margin-top: 0.4rem; color: #444; }

        .review-form {
            background: var(--pink-soft);
            border-radius: 18px;
            padding: 1.5rem;
        }

        .btn-submit-review {
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 10px 24px;
            font-weight: 600;
        }
        .btn-submit-review:hover { background: var(--brand-dark); color: #fff; }

        .empty-reviews { color: #aaa; text-align: center; padding: 2rem 0; }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg bg-white py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/">food<span class="brand-red">hub</span></a>
        <div class="d-flex">
            <a href="/" class="nav-link-custom">Home</a>
            <a href="/menu" class="nav-link-custom">Menu</a>
        </div>
    </div>
</nav>

<div class="container mt-4 pb-5">

    <a href="/menu" class="back-link">&larr; Back to menu</a>

    <div class="dish-hero p-4 mt-3 row align-items-center g-4">
        <div class="col-md-5">
            <img src="<%= dish.image %>" alt="<%= dish.name %>">
        </div>
        <div class="col-md-7">
            <span class="category-badge"><%= dish.category %></span>
            <h1 class="fw-bold"><%= dish.name %></h1>
            <p class="text-muted"><%= dish.description %></p>
            <div class="price mb-2">$<%= dish.price.toFixed(2) %></div>

            <% if (reviewCount > 0) { %>
                <div class="rating-summary">
                    <span class="stars"><%= '★'.repeat(Math.round(avgRating)) %><%= '☆'.repeat(5 - Math.round(avgRating)) %></span>
                    <%= avgRating.toFixed(1) %> out of 5
                    (<%= reviewCount %> review<%= reviewCount === 1 ? '' : 's' %>)
                </div>
            <% } else { %>
                <div class="text-muted">No reviews yet — be the first!</div>
            <% } %>
        </div>
    </div>

    <div class="row mt-5 g-4">

        <!-- Review list -->
        <div class="col-md-7">
            <h4 class="fw-bold mb-3">Customer Reviews</h4>

            <% if (reviews.length === 0) { %>
                <div class="empty-reviews">
                    <div style="font-size:2.5rem;">🍽️</div>
                    <p>No reviews yet for this dish.</p>
                </div>
            <% } else { %>
                <% reviews.forEach(review => { %>
                    <div class="review-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <span class="review-name"><%= review.name %></span>
                            <span class="stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></span>
                        </div>
                        <div class="review-date"><%= new Date(review.date).toLocaleDateString() %></div>
                        <% if (review.comment) { %>
                            <p class="review-comment"><%= review.comment %></p>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- Review form -->
        <div class="col-md-5">
            <div class="review-form">
                <h5 class="fw-bold mb-3">Leave a Review</h5>
                <form action="/dish/<%= dish.id %>/reviews" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Your Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Sarah" maxlength="50">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <select name="rating" class="form-select" required>
                            <option value="5">★★★★★ - Excellent</option>
                            <option value="4">★★★★☆ - Good</option>
                            <option value="3">★★★☆☆ - Okay</option>
                            <option value="2">★★☆☆☆ - Not great</option>
                            <option value="1">★☆☆☆☆ - Poor</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Comment</label>
                        <textarea name="comment" class="form-control" rows="3" maxlength="500" placeholder="What did you think?"></textarea>
                    </div>
                    <button type="submit" class="btn-submit-review w-100">Submit Review</button>
                </form>
            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
