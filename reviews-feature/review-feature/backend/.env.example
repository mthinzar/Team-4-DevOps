# Copy this file to .env before running the server

PORT=5000
MONGO_URI=mongodb://localhost:27017/launchlab_reviews
JWT_SECRET=change_this_to_a_long_random_secret

# If true, a customer MUST have a Completed order for the item before they
# can review it. Keep this false while Justyn's Order system is still being
# built, so you can demo reviews independently. Flip to true once Order
# integration is ready.
REQUIRE_VERIFIED_PURCHASE=false
