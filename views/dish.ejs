<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= dish.name %> — FoodHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand: #e23744;
            --brand-dark: #c52d39;
            --pink: #fcd7dd;
            --pink-soft: #ffeef1;
        }

        body { font-family: 'Poppins', sans-serif; background-color: #ffffff; color: #1a1a1a; }
        .brand-red { color: var(--brand); }

        /* Navbar — identical to menu.ejs */
        .navbar-brand img { height: 72px; }
        .nav-link-custom {
            color: #1a1a1a; font-weight: 500; margin: 0 1rem;
            text-decoration: none; position: relative;
        }
        .nav-link-custom::after {
            content: ''; position: absolute; left: 0; bottom: -6px;
            width: 0; height: 2px; background: var(--brand); transition: 0.25s;
        }
        .nav-link-custom:hover { color: var(--brand); }
        .nav-link-custom:hover::after { width: 100%; }
        .btn-login {
            border: 1px solid var(--brand); color: var(--brand);
            background: #fff; border-radius: 8px;
        }
        .btn-login:hover { background: var(--brand); color: #fff; }
        .btn-signup {
            background: var(--brand); color: #fff;
            border: 1px solid var(--brand); border-radius: 8px;
        }
        .btn-signup:hover { background: var(--brand-dark); color: #fff; }

        /* Cart button + badge — identical to menu.ejs */
        .btn-cart {
            border: 1px solid var(--brand);
            background: #fff;
            border-radius: 8px;
            font-size: 1.1rem;
            line-height: 1;
            padding: 0.35rem 0.6rem;
            position: relative;
        }
        .btn-cart:hover { background: var(--pink-soft); }
        .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--brand);
            color: #fff;
            font-size: 0.68rem;
            font-weight: 700;
            min-width: 20px;
            height: 20px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
        }

        /* Cart drawer — identical to menu.ejs */
        .cart-item { display: flex; gap: 0.75rem; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid #f0d0d4; }
        .cart-item img { width: 52px; height: 52px; object-fit: cover; border-radius: 10px; }
        .cart-item-name { font-weight: 600; font-size: 0.9rem; }
        .cart-item-price { color: var(--brand); font-weight: 600; font-size: 0.85rem; }
        .qty-box { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 0.3rem; }
        .qty-box button {
            border: 1px solid #e0a4ac; background: #fff;
            width: 26px; height: 26px; border-radius: 6px;
            line-height: 1; font-weight: 700; color: #1a1a1a;
        }
        .qty-box button:hover { background: var(--pink-soft); }
        .cart-remove { background: none; border: none; color: #7a7a7a; font-size: 0.78rem; }
        .cart-remove:hover { color: var(--brand); text-decoration: underline; }
        .cart-empty { text-align: center; color: #7a7a7a; padding: 3rem 1rem; }
        .cart-footer { border-top: 1px solid #f0d0d4; padding-top: 1rem; margin-top: 0.5rem; }
        .btn-checkout {
            background: var(--brand); color: #fff; border: none;
            border-radius: 10px; padding: 0.6rem; font-weight: 600;
        }
        .btn-checkout:hover { background: var(--brand-dark); color: #fff; }

        /* Back link */
        .back-link { color: var(--brand); font-weight: 500; text-decoration: none; font-size: 0.9rem; }
        .back-link:hover { color: var(--brand-dark); }

        /* Dish hero */
        .dish-hero {
            background: linear-gradient(120deg, #fde2e7 0%, #fcd7dd 60%, #f9c4cd 100%);
            border-radius: 24px;
        }
        .dish-img-wrap {
            background: var(--pink-soft);
            padding: 1.5rem 0 1rem;
            border-radius: 20px;
            text-align: center;
        }
        .dish-img {
            width: 160px; height: 160px;
            object-fit: cover; border-radius: 50%;
            border: 4px solid #fff;
            box-shadow: 0 6px 14px rgba(0,0,0,0.12);
        }
        .dish-badge {
            display: inline-block;
            background: var(--brand); color: #fff;
            font-size: 0.65rem; font-weight: 600;
            letter-spacing: 0.5px; text-transform: uppercase;
            padding: 0.25rem 0.75rem; border-radius: 20px;
            margin-bottom: 0.5rem;
        }
        .dish-price-lg { color: var(--brand); font-weight: 700; font-size: 1.3rem; }
        .stars-lg { color: #f5a623; font-size: 1.2rem; letter-spacing: 2px; }

        .btn-add-cart-lg {
            background: var(--brand); color: #fff; border: none;
            padding: 0.55rem 1.6rem; border-radius: 10px;
            font-weight: 600; transition: 0.25s; margin-top: 0.75rem;
        }
        .btn-add-cart-lg:hover { background: var(--brand-dark); color: #fff; }

        /* Review cards */
        .review-card {
            border: 1px solid #f0d0d4; border-radius: 14px;
            padding: 1rem 1.25rem; margin-bottom: 1rem; background: #fff;
        }
        .review-name { font-weight: 600; font-size: 0.9rem; }
        .review-date { color: #aaa; font-size: 0.75rem; }
        .review-comment { color: #444; font-size: 0.85rem; margin-top: 0.35rem; margin-bottom: 0; }
        .stars-sm { color: #f5a623; font-size: 0.85rem; }
        .empty-reviews { text-align: center; color: #aaa; padding: 2.5rem 0; }

        /* Review form */
        .review-form { background: var(--pink-soft); border-radius: 18px; padding: 1.5rem; }
        .review-form .form-control:focus,
        .review-form .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 0.2rem rgba(226,55,68,0.15);
        }
        .btn-submit-review {
            background: var(--brand); color: #fff; border: none;
            border-radius: 10px; padding: 0.65rem; font-weight: 600;
            width: 100%; transition: 0.25s;
        }
        .btn-submit-review:hover { background: var(--brand-dark); color: #fff; }

        /* Auth modals — identical to menu.ejs */
        .auth-modal .modal-content { border: none; border-radius: 18px; overflow: hidden; }
        .auth-header {
            background: linear-gradient(120deg, #fde2e7 0%, #f9c4cd 100%);
            text-align: center; padding: 1.75rem 1.5rem 1.25rem; position: relative;
        }
        .auth-header img { height: 56px; }
        .auth-header h5 { font-weight: 700; margin-top: 0.75rem; margin-bottom: 0; }
        .auth-header p { font-size: 0.85rem; color: #6b4a4f; margin: 0; }
        .auth-body { padding: 1.5rem; }
        .auth-body .form-label { font-weight: 500; font-size: 0.85rem; }
        .auth-body .form-control { border-radius: 10px; padding: 0.6rem 0.9rem; }
        .auth-body .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 0.2rem rgba(226,55,68,0.15);
        }
        .btn-auth {
            background: var(--brand); color: #fff; border: none;
            border-radius: 10px; padding: 0.65rem; font-weight: 600;
            width: 100%; transition: 0.25s;
        }
        .btn-auth:hover { background: var(--brand-dark); color: #fff; }
        .auth-switch { font-size: 0.85rem; text-align: center; margin-top: 1rem; }
        .auth-switch a { color: var(--brand); text-decoration: none; font-weight: 600; cursor: pointer; }
        .auth-switch a:hover { text-decoration: underline; }

        /* Footer — identical to menu.ejs */
        footer { background: #1a1a1a; color: #ddd; }
        footer a { color: #ddd; text-decoration: none; }
        footer a:hover { color: var(--brand); }
    </style>
</head>

<body>

<!-- Navbar — identical to menu.ejs -->
<nav class="navbar navbar-expand-lg bg-white py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="/">
            <img src="<%= images.logo %>" alt="FoodHub"
                 onerror="this.style.display='none';document.getElementById('brandText').style.display='inline';">
            <span id="brandText" style="display:none;">food<span class="brand-red">hub</span></span>
        </a>

        <div class="d-none d-lg-flex flex-grow-1 justify-content-center">
            <a href="/" class="nav-link-custom">Home</a>
            <a href="/menu" class="nav-link-custom active">Menu</a>
            <a href="/#popular" class="nav-link-custom">Categories</a>
        </div>

        <div class="d-flex align-items-center">
            <button type="button" class="btn btn-cart position-relative me-2" id="cartButton" aria-label="Open cart">
                &#128722;<span class="cart-badge" id="cartBadge">0</span>
            </button>
            <button type="button" class="btn btn-login me-2" data-bs-toggle="modal" data-bs-target="#loginModal">Login</button>
            <button type="button" class="btn btn-signup" data-bs-toggle="modal" data-bs-target="#signupModal">Sign Up</button>
        </div>
    </div>
</nav>

<!-- Page content -->
<div class="container mt-4 pb-5">

    <a href="/menu" class="back-link">&larr; Back to menu</a>

    <!-- Dish hero -->
    <div class="dish-hero p-4 mt-3 row align-items-center g-4">
        <div class="col-md-4">
            <div class="dish-img-wrap">
                <img src="<%= dish.image %>" class="dish-img" alt="<%= dish.name %>">
            </div>
        </div>
        <div class="col-md-8">
            <span class="dish-badge"><%= dish.category %></span>
            <h2 class="fw-bold mb-1"><%= dish.name %></h2>
            <p class="text-muted mb-2"><%= dish.description %></p>
            <div class="dish-price-lg mb-2">$<%= dish.price.toFixed(2) %></div>

            <% if (reviewCount > 0) { %>
                <div>
                    <span class="stars-lg"><%= '★'.repeat(Math.round(avgRating)) %><%= '☆'.repeat(5 - Math.round(avgRating)) %></span>
                    <span class="fw-semibold ms-1"><%= avgRating.toFixed(1) %></span>
                    <span class="text-muted" style="font-size:0.85rem;">
                        (<%= reviewCount %> review<%= reviewCount === 1 ? '' : 's' %>)
                    </span>
                </div>
            <% } else { %>
                <div class="text-muted" style="font-size:0.85rem;">No reviews yet — be the first!</div>
            <% } %>

            <button class="btn btn-add-cart-lg add-to-cart"
                    data-name="<%= dish.name %>"
                    data-price="<%= dish.price %>"
                    data-image="<%= dish.image %>">Add to cart</button>
        </div>
    </div>

    <!-- Reviews + form -->
    <div class="row mt-5 g-4">

        <!-- Review list -->
        <div class="col-md-7">
            <h5 class="fw-bold mb-3">Customer Reviews</h5>

            <% if (reviews.length === 0) { %>
                <div class="empty-reviews">
                    <div style="font-size:2.5rem;">🍽️</div>
                    <p class="mt-2">No reviews yet for this dish.</p>
                </div>
            <% } else { %>
                <% reviews.forEach(function(review) { %>
                    <div class="review-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <span class="review-name"><%= review.name %></span>
                            <span class="stars-sm"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></span>
                        </div>
                        <div class="review-date"><%= new Date(review.date).toLocaleDateString() %></div>
                        <% if (review.comment) { %>
                            <p class="review-comment"><%= review.comment %></p>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>
        </div>

        <!-- Review form -->
        <div class="col-md-5">
            <div class="review-form">
                <h6 class="fw-bold mb-3">Leave a Review</h6>
                <form action="/dish/<%= dish.id %>/reviews" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Your Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Sarah" maxlength="50">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <select name="rating" class="form-select" required>
                            <option value="5">★★★★★ — Excellent</option>
                            <option value="4">★★★★☆ — Good</option>
                            <option value="3">★★★☆☆ — Okay</option>
                            <option value="2">★★☆☆☆ — Not great</option>
                            <option value="1">★☆☆☆☆ — Poor</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Comment</label>
                        <textarea name="comment" class="form-control" rows="3" maxlength="500" placeholder="What did you think?"></textarea>
                    </div>
                    <button type="submit" class="btn-submit-review">Submit Review</button>
                </form>
            </div>
        </div>

    </div>
</div>

<!-- Footer — identical to menu.ejs -->
<footer class="py-4">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
        <span class="mb-2 mb-md-0">&copy; 2026 FoodHub. All rights reserved.</span>
        <div>
            <a href="/" class="me-3">Home</a>
            <a href="/menu" class="me-3">Menu</a>
            <a href="/#popular">Categories</a>
        </div>
    </div>
</footer>

<!-- Login Modal — identical to menu.ejs -->
<div class="modal fade auth-modal" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="auth-header">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img src="<%= images.logo %>" alt="FoodHub">
                <h5>Welcome Back</h5>
                <p>Log in to continue ordering</p>
            </div>
            <div class="auth-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="Enter your password" required>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe" style="font-size:0.82rem;">Remember me</label>
                        </div>
                        <a href="#" style="font-size:0.82rem; color:var(--brand); text-decoration:none;">Forgot password?</a>
                    </div>
                    <button type="submit" class="btn-auth">Login</button>
                </form>
                <p class="auth-switch">Don't have an account?
                    <a data-bs-toggle="modal" data-bs-target="#signupModal" data-bs-dismiss="modal">Sign Up</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Sign Up Modal — identical to menu.ejs -->
<div class="modal fade auth-modal" id="signupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="auth-header">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img src="<%= images.logo %>" alt="FoodHub">
                <h5>Create Account</h5>
                <p>Join FoodHub and start ordering</p>
            </div>
            <div class="auth-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" placeholder="Your name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="Create a password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" placeholder="Re-enter your password" required>
                    </div>
                    <button type="submit" class="btn-auth">Sign Up</button>
                </form>
                <p class="auth-switch">Already have an account?
                    <a data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">Login</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Cart Drawer — identical to menu.ejs -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="cartDrawer" aria-labelledby="cartDrawerLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="cartDrawerLabel">Your order</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column">
        <div id="cartItems" class="flex-grow-1"></div>
        <div class="cart-footer">
            <div class="d-flex justify-content-between mb-3">
                <span class="fw-semibold">Subtotal</span>
                <span class="fw-bold" id="cartSubtotal">$0.00</span>
            </div>
            <a href="/checkout" class="btn btn-checkout w-100">Go to checkout</a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/cart.js"></script>

</body>
</html>
