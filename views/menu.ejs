<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .food-card {
            transition: 0.25s;
        }

        .food-card:hover {
            transform: translateY(-5px);
        }

        .food-image {
            height: 220px;
            object-fit: cover;
        }
    </style>
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-danger shadow">
    <div class="container">

        <a class="navbar-brand fw-bold" href="/">
            🍔 FoodHub
        </a>

        <div>
            <a href="/" class="btn btn-outline-light me-2">Home</a>
            <a href="/menu" class="btn btn-light">Menu</a>
        </div>

    </div>
</nav>

<div class="container py-4">

    <h1 class="mb-4">
        Menu
    </h1>

    <!-- Search Bar -->
    <div class="mb-4">
        <input
            type="text"
            class="form-control"
            placeholder="Search food...">
    </div>

    <div class="row">

        <% foods.forEach(food => { %>

        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card food-card shadow-sm h-100">

                <img
                    src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800"
                    class="card-img-top food-image"
                    alt="Food">

                <div class="card-body">

                    <h5 class="card-title">
                        <%= food.name %>
                    </h5>

                    <p class="text-muted">
                        <%= food.description %>
                    </p>

                    <h5 class="text-danger">
                        $<%= food.price.toFixed(2) %>
                    </h5>

                </div>

                <div class="card-footer bg-white border-0">
                    <button class="btn btn-danger w-100">
                        Add to Cart
                    </button>
                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

</body>
</html>