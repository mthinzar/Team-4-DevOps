                    <div class="mb-3">
                        <label class="form-label">Phone number</label>
                        <div class="input-group">
                            <span class="input-group-text">+65</span>
                            <input type="tel" id="signupPhone" class="form-control" placeholder="9123 4567" autocomplete="tel" maxlength="9">
                        </div>
                        <div id="signupPhoneErr" class="field-err">Enter a valid 8-digit Singapore number (starts with 6, 8 or 9).</div>
                    </div>
                    <button type="button" id="signupSendBtn" class="btn-auth">Send Security Code</button>
                </div>

                <!-- Step 2: security code -->
                <div id="signupStep2" style="display:none;">
                    <p class="code-hint mb-3">
                        We sent a 6-digit code to <strong id="signupSentTo"></strong>.
                        <span class="text-muted">(Demo: enter any 6 digits)</span>
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Security code</label>
                        <input type="text" inputmode="numeric" maxlength="6" id="signupCode" class="form-control" placeholder="● ● ● ● ● ●">
                        <div id="signupCodeErr" class="field-err">Enter the 6-digit code.</div>
                    </div>
                    <button type="button" id="signupVerifyBtn" class="btn-auth">Create Account</button>
                    <div class="text-center mt-2">
                        <button type="button" class="btn-link-brand" id="signupResend">Edit details</button>
