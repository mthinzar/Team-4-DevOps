<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodHub - Order Your Favourite Food</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand: #e23744;
            --brand-dark: #c52d39;
            --pink: #fcd7dd;
            --pink-soft: #ffeef1;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #ffffff;
            color: #1a1a1a;
        }

        .brand-red { color: var(--brand); }

        /* Navbar */
        .navbar-brand img {
            height: 72px;
        }

        .nav-link-custom {
            color: #1a1a1a;
            font-weight: 500;
            margin: 0 1rem;
            text-decoration: none;
            position: relative;
        }

        .nav-link-custom::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -6px;
            width: 0;
            height: 2px;
            background: var(--brand);
            transition: 0.25s;
        }

        .nav-link-custom:hover { color: var(--brand); }
        .nav-link-custom:hover::after { width: 100%; }

        .btn-login {
            border: 1px solid var(--brand);
            color: var(--brand);
            background: #fff;
            border-radius: 8px;
        }
        .btn-login:hover { background: var(--brand); color: #fff; }

        .btn-signup {
            background: var(--brand);
            color: #fff;
            border: 1px solid var(--brand);
            border-radius: 8px;
        }
        .btn-signup:hover { background: var(--brand-dark); color: #fff; }

        /* Hero */
        .hero {
            background: linear-gradient(120deg, #fde2e7 0%, #fcd7dd 60%, #f9c4cd 100%);
            border-radius: 24px;
            overflow: hidden;
            position: relative;
        }

        /* decorative blobs */
        .hero::before {
            content: '';
            position: absolute;
            width: 260px;
            height: 260px;
            background: rgba(255, 255, 255, 0.35);
            border-radius: 50%;
            top: -80px;
            right: -40px;
        }
        .hero::after {
            content: '';
            position: absolute;
            width: 180px;
            height: 180px;
            background: rgba(226, 55, 68, 0.08);
            border-radius: 50%;
            bottom: -60px;
            left: 30%;
        }

        .hero-content { position: relative; z-index: 2; }

        .hero h1 {
            font-weight: 800;
            line-height: 1.1;
            font-size: clamp(2.2rem, 5vw, 3.6rem);
        }

        .hero .tagline {
            color: #6b4a4f;
            font-weight: 400;
        }

        .btn-order {
            background: var(--brand);
            color: #fff;
            border: 1px solid var(--brand);
            padding: 0.65rem 1.8rem;
            border-radius: 10px;
            font-weight: 600;
            box-shadow: 0 8px 18px rgba(226, 55, 68, 0.3);
            transition: 0.25s;
        }
        .btn-order:hover { background: var(--brand-dark); color: #fff; transform: translateY(-2px); }

        .btn-view-menu {
            background: #fff;
            color: #1a1a1a;
            border: 1px solid #e0a4ac;
            padding: 0.65rem 1.8rem;
            border-radius: 10px;
            font-weight: 600;
            transition: 0.25s;
        }
        .btn-view-menu:hover { background: #fff5f6; transform: translateY(-2px); }

        .hero-img {
            max-height: 360px;
            width: 100%;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 18px 34px rgba(0,0,0,0.18);
            animation: float 4s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-14px); }
        }

        /* Section heading */
        .section-title {
            font-weight: 700;
        }
        .section-title .underline {
            display: block;
            width: 60px;
            height: 4px;
            background: var(--brand);
            border-radius: 4px;
            margin-top: 6px;
        }

        .view-all {
            color: var(--brand);
            text-decoration: none;
            font-weight: 500;
        }
        .view-all:hover { color: var(--brand-dark); }

        /* Dish cards */
        .dish-card {
            border: 1px solid #f0d0d4;
            border-radius: 16px 16px 90px 90px;
            text-align: center;
            transition: 0.3s;
            background: #fff;
            height: 100%;
        }
        .dish-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 14px 28px rgba(226, 55, 68, 0.16);
            border-color: var(--brand);
        }

        .dish-img-wrap {
            background: var(--pink-soft);
            padding: 1.25rem 0 0.75rem;
            border-radius: 16px 16px 50% 50%;
        }

        .dish-img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50%;
            border: 4px solid #fff;
            box-shadow: 0 6px 14px rgba(0,0,0,0.12);
        }

        .dish-name { font-weight: 600; font-size: 1rem; margin-top: 0.75rem; }
        .dish-desc { font-size: 0.78rem; color: #7a7a7a; padding: 0 0.9rem; min-height: 48px; }
        .dish-price { color: var(--brand); font-weight: 700; font-size: 1rem; }

        .btn-add-cart {
            background: var(--brand);
            color: #fff;
            font-size: 0.8rem;
            border: none;
            padding: 0.45rem 1.3rem;
            border-radius: 8px;
            margin-bottom: 1.4rem;
            font-weight: 500;
            transition: 0.25s;
        }
        .btn-add-cart:hover { background: var(--brand-dark); color: #fff; }

        /* Feature strip */
        .feature-strip {
            background: var(--pink-soft);
            border-radius: 20px;
        }
        .feature-box .icon {
            font-size: 2rem;
        }
        .feature-box h6 { font-weight: 600; margin-top: 0.5rem; }
        .feature-box p { font-size: 0.82rem; color: #7a7a7a; }

        /* Auth modals */
        .auth-modal .modal-content {
            border: none;
            border-radius: 18px;
            overflow: hidden;
        }
        .auth-header {
            background: linear-gradient(120deg, #fde2e7 0%, #f9c4cd 100%);
            text-align: center;
            padding: 1.75rem 1.5rem 1.25rem;
            position: relative;
        }
        .auth-header img { height: 56px; }
        .auth-header h5 { font-weight: 700; margin-top: 0.75rem; margin-bottom: 0; }
        .auth-header p { font-size: 0.85rem; color: #6b4a4f; margin: 0; }
        .auth-body { padding: 1.5rem; }
        .auth-body .form-label { font-weight: 500; font-size: 0.85rem; }
        .auth-body .form-control {
            border-radius: 10px;
            padding: 0.6rem 0.9rem;
        }
        .auth-body .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 0.2rem rgba(226, 55, 68, 0.15);
        }
        .btn-auth {
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.65rem;
            font-weight: 600;
            width: 100%;
            transition: 0.25s;
        }
        .btn-auth:hover { background: var(--brand-dark); color: #fff; }
        .auth-switch { font-size: 0.85rem; text-align: center; margin-top: 1rem; }
        .auth-switch a { color: var(--brand); text-decoration: none; font-weight: 600; cursor: pointer; }
        .auth-switch a:hover { text-decoration: underline; }
        .auth-divider {
            display: flex; align-items: center; text-align: center;
            color: #aaa; font-size: 0.78rem; margin: 1rem 0;
        }
        .auth-divider::before, .auth-divider::after {
            content: ''; flex: 1; border-bottom: 1px solid #eee;
        }
        .auth-divider span { padding: 0 0.75rem; }

        /* Footer */
        footer {
            background: #1a1a1a;
            color: #ddd;
        }
        footer a { color: #ddd; text-decoration: none; }
        footer a:hover { color: var(--brand); }
    </style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="/">
            <img src="<%= images.logo %>" alt="FoodHub"
                 onerror="this.style.display='none';document.getElementById('brandText').style.display='inline';">
            <span id="brandText" style="display:none;">food<span class="brand-red">hub</span></span>
        </a>

        <div class="d-none d-lg-flex flex-grow-1 justify-content-center">
            <a href="/" class="nav-link-custom">Home</a>
            <a href="/menu" class="nav-link-custom">Menu</a>
            <a href="#popular" class="nav-link-custom">Categories</a>
        </div>

        <div>
            <button type="button" class="btn btn-login me-2" data-bs-toggle="modal" data-bs-target="#loginModal">Login</button>
            <button type="button" class="btn btn-signup" data-bs-toggle="modal" data-bs-target="#signupModal">Sign Up</button>
    <title>Food Ordering System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-danger shadow">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            🍔 FoodHub
        </a>

        <div>
            <a href="/" class="btn btn-outline-light me-2">Home</a>
            <a href="/menu" class="btn btn-light">Menu</a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="container mt-4">
    <div class="hero p-4 p-md-5">
        <div class="row align-items-center hero-content">

            <div class="col-md-6">
                <h1>
                    Order Your<br>
                    Favourite Food<br>
                    <span class="brand-red">Fast &amp; Easy</span>
                </h1>

                <p class="tagline mt-3 mb-4">
                    Freshly prepared meals delivered hot to your door.
                    Browse the menu, order in seconds, and enjoy.
                </p>

                <div>
                    <a href="/menu" class="btn btn-order me-2">Order Now &rarr;</a>
                    <a href="/menu" class="btn btn-view-menu">View Menu</a>
                </div>
            </div>

            <div class="col-md-6 text-center mt-4 mt-md-0">
                <img src="<%= images.hero %>" class="img-fluid hero-img" alt="Delicious food bowl">
            </div>

        </div>
    </div>
</section>

<!-- Popular Dishes -->
<section class="container py-5" id="popular">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">
            Popular Dishes
            <span class="underline"></span>
        </h2>
        <a href="/menu" class="view-all">View All &rarr;</a>
    </div>

    <div class="row g-3">

        <% popularDishes.forEach(dish => { %>

        <div class="col-6 col-md-4 col-lg">

            <div class="dish-card">

                <div class="dish-img-wrap">
                    <img src="<%= dish.image %>" class="dish-img" alt="<%= dish.name %>">
                </div>

                <div class="px-2">
                    <div class="dish-name"><%= dish.name %></div>
                    <p class="dish-desc"><%= dish.description %></p>
                    <div class="dish-price mb-2">$<%= dish.price.toFixed(2) %></div>
                    <button class="btn btn-add-cart">Add to cart</button>
                </div>

            </div>

        </div>

        <% }) %>
<section class="container py-5">

    <div class="row align-items-center">

        <div class="col-md-6">
            <h1 class="display-4 fw-bold">
                Order Your Favourite Meals
            </h1>

            <p class="lead text-muted">
                Browse delicious food, place orders, track delivery status,
                and leave reviews all in one place.
            </p>

            <a href="/menu" class="btn btn-danger btn-lg">
                Browse Menu
            </a>
        </div>

        <div class="col-md-6 text-center">
            <img
                src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=900"
                class="img-fluid rounded shadow"
                alt="Food">
        </div>

    </div>

</section>

<!-- Feature Strip -->
<section class="container pb-5">
    <div class="feature-strip p-4">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">🚚</div>
                <h6>Fast Delivery</h6>
                <p>Hot meals at your door in 30 minutes.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">🥗</div>
                <h6>Fresh Ingredients</h6>
                <p>Sourced fresh and cooked to order.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">💳</div>
                <h6>Easy Payment</h6>
                <p>Secure checkout with multiple options.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">⭐</div>
                <h6>Top Rated</h6>
                <p>Loved by thousands of happy customers.</p>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="py-4">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
        <span class="mb-2 mb-md-0">&copy; 2026 FoodHub. All rights reserved.</span>
        <div>
            <a href="/" class="me-3">Home</a>
            <a href="/menu" class="me-3">Menu</a>
            <a href="#popular">Categories</a>
        </div>
    </div>
</footer>

<!-- Login Modal -->
<div class="modal fade auth-modal" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="auth-header">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img src="<%= images.logo %>" alt="FoodHub">
                <h5>Welcome Back</h5>
                <p>Log in to continue ordering</p>
            </div>

            <div class="auth-body">
                <!-- TODO: hook up to backend later (action="/login" method="POST") -->
                <form>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="Enter your password" required>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe" style="font-size:0.82rem;">Remember me</label>
                        </div>
                        <a href="#" style="font-size:0.82rem; color:var(--brand); text-decoration:none;">Forgot password?</a>
                    </div>
                    <button type="submit" class="btn-auth">Login</button>
                </form>

                <p class="auth-switch">
                    Don't have an account?
                    <a data-bs-toggle="modal" data-bs-target="#signupModal" data-bs-dismiss="modal">Sign Up</a>
                </p>
            </div>

        </div>
    </div>
</div>

<!-- Sign Up Modal -->
<div class="modal fade auth-modal" id="signupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="auth-header">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img src="<%= images.logo %>" alt="FoodHub">
                <h5>Create Account</h5>
                <p>Join FoodHub and start ordering</p>
            </div>

            <div class="auth-body">
                <!-- TODO: hook up to backend later (action="/signup" method="POST") -->
                <form>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" placeholder="Your name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="Create a password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" placeholder="Re-enter your password" required>
                    </div>
                    <button type="submit" class="btn-auth">Sign Up</button>
                </form>

                <p class="auth-switch">
                    Already have an account?
                    <a data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">Login</a>
                </p>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
<!-- Features -->
<section class="container pb-5">

    <h2 class="text-center mb-4">
        System Features
    </h2>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>🍔 Menu</h4>
                    <p>Browse available food items.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>🔐 Login</h4>
                    <p>User authentication system.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>📦 Tracking</h4>
                    <p>Track order preparation status.</p>
                </div>
            </div>
        </div>

    </div>

</section>

</body>
</html>
