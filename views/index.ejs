<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Auth: phone + security code (demo) and logged-in state -->
<script>
(function () {
    const STORE_KEY = 'foodhubUser';

    function getUser() {
        try { return JSON.parse(localStorage.getItem(STORE_KEY)); }
        catch (e) { return null; }
    }

    function renderAuth() {
        const user = getUser();
        const authButtons = document.getElementById('authButtons');
        const userMenu = document.getElementById('userMenu');
        if (user && user.name) {
            authButtons.classList.add('d-none');
            userMenu.classList.remove('d-none');
            document.getElementById('userName').textContent = user.name;
            document.getElementById('userInitial').textContent = user.name.trim().charAt(0).toUpperCase();
        } else {
            authButtons.classList.remove('d-none');
            userMenu.classList.add('d-none');
        }
    }

    function loginUser(name) {
        localStorage.setItem(STORE_KEY, JSON.stringify({ name: name }));
        renderAuth();
    }

    document.getElementById('logoutBtn').addEventListener('click', function (e) {
        e.preventDefault();
        localStorage.removeItem(STORE_KEY);
        renderAuth();
    });

    function closeModal(id) {
        const inst = bootstrap.Modal.getInstance(document.getElementById(id));
        if (inst) inst.hide();
    }

    function showStep(prefix, step) {
        document.getElementById(prefix + 'Step1').style.display = step === 1 ? 'block' : 'none';
        document.getElementById(prefix + 'Step2').style.display = step === 2 ? 'block' : 'none';
    }

    // Singapore mobile/landline: 8 digits starting with 6, 8 or 9
    const cleanPhone = v => v.replace(/\s+/g, '');
    const validPhone = v => /^[689]\d{7}$/.test(cleanPhone(v));
    const validCode  = v => /^\d{6}$/.test(v.replace(/\s+/g, ''));

    // Wire up an OTP flow for a given modal prefix ('login' / 'signup')
    function setupOtp(prefix, opts) {
        const phone = document.getElementById(prefix + 'Phone');
        const code  = document.getElementById(prefix + 'Code');

        document.getElementById(prefix + 'SendBtn').addEventListener('click', function () {
            if (opts.requireName) {
                const name = document.getElementById(prefix + 'Name');
                if (!name.value.trim()) {
                    document.getElementById(prefix + 'NameErr').style.display = 'block';
                    return;
                }
                document.getElementById(prefix + 'NameErr').style.display = 'none';
            }
            if (!validPhone(phone.value)) {
                document.getElementById(prefix + 'PhoneErr').style.display = 'block';
                return;
            }
            document.getElementById(prefix + 'PhoneErr').style.display = 'none';
            document.getElementById(prefix + 'SentTo').textContent = '+65 ' + cleanPhone(phone.value);
            showStep(prefix, 2);
            code.value = '';
            code.focus();
        });

        document.getElementById(prefix + 'VerifyBtn').addEventListener('click', function () {
            if (!validCode(code.value)) {
                document.getElementById(prefix + 'CodeErr').style.display = 'block';
                return;
            }
            document.getElementById(prefix + 'CodeErr').style.display = 'none';
            opts.onVerified();
        });

        document.getElementById(prefix + 'Resend').addEventListener('click', function () {
            showStep(prefix, 1);
        });
    }

    setupOtp('login', {
        requireName: false,
        onVerified: function () {
            loginUser('Friend');
            closeModal('loginModal');
            showStep('login', 1);
        }
    });

    setupOtp('signup', {
        requireName: true,
        onVerified: function () {
            const name = (document.getElementById('signupName').value || '').trim() || 'Friend';
            loginUser(name);
            closeModal('signupModal');
            showStep('signup', 1);
        }
    });

    renderAuth();
})();
</script>
<script src="/js/cart.js"></script>

</body>
</html>
