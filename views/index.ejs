<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodHub - Order Your Favourite Food</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand: #e23744;
            --brand-dark: #c52d39;
            --pink: #fcd7dd;
            --pink-soft: #ffeef1;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #ffffff;
            color: #1a1a1a;
        }

        .brand-red { color: var(--brand); }

        /* Navbar */
        .navbar-brand img {
            height: 72px;
        }

        .nav-link-custom {
            color: #1a1a1a;
            font-weight: 500;
            margin: 0 1rem;
            text-decoration: none;
            position: relative;
        }

        .nav-link-custom::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -6px;
            width: 0;
            height: 2px;
            background: var(--brand);
            transition: 0.25s;
        }

        .nav-link-custom:hover { color: var(--brand); }
        .nav-link-custom:hover::after { width: 100%; }

        .btn-login {
            border: 1px solid var(--brand);
            color: var(--brand);
            background: #fff;
            border-radius: 8px;
        }
        .btn-login:hover { background: var(--brand); color: #fff; }

        .btn-signup {
            background: var(--brand);
            color: #fff;
            border: 1px solid var(--brand);
            border-radius: 8px;
        }
        .btn-signup:hover { background: var(--brand-dark); color: #fff; }

        /* Logged-in user menu */
        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--brand);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.95rem;
        }
        .btn-user {
            border: 1px solid #f0d0d4;
            background: #fff;
            border-radius: 30px;
            padding: 0.25rem 0.75rem 0.25rem 0.35rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }
        .btn-user:hover { background: var(--pink-soft); }

        /* Hero */
        .hero {
            background: linear-gradient(120deg, #fde2e7 0%, #fcd7dd 60%, #f9c4cd 100%);
            border-radius: 24px;
            overflow: hidden;
            position: relative;
        }

        /* decorative blobs */
        .hero::before {
            content: '';
            position: absolute;
            width: 260px;
            height: 260px;
            background: rgba(255, 255, 255, 0.35);
            border-radius: 50%;
            top: -80px;
            right: -40px;
        }
        .hero::after {
            content: '';
            position: absolute;
            width: 180px;
            height: 180px;
            background: rgba(226, 55, 68, 0.08);
            border-radius: 50%;
            bottom: -60px;
            left: 30%;
        }

        .hero-content { position: relative; z-index: 2; }

        .hero h1 {
            font-weight: 800;
            line-height: 1.1;
            font-size: clamp(2.2rem, 5vw, 3.6rem);
        }

        .hero .tagline {
            color: #6b4a4f;
            font-weight: 400;
        }

        .btn-order {
            background: var(--brand);
            color: #fff;
            border: 1px solid var(--brand);
            padding: 0.65rem 1.8rem;
            border-radius: 10px;
            font-weight: 600;
            box-shadow: 0 8px 18px rgba(226, 55, 68, 0.3);
            transition: 0.25s;
        }
        .btn-order:hover { background: var(--brand-dark); color: #fff; transform: translateY(-2px); }

        .btn-view-menu {
            background: #fff;
            color: #1a1a1a;
            border: 1px solid #e0a4ac;
            padding: 0.65rem 1.8rem;
            border-radius: 10px;
            font-weight: 600;
            transition: 0.25s;
        }
        .btn-view-menu:hover { background: #fff5f6; transform: translateY(-2px); }

        /* Hero carousel */
        .hero-carousel {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 18px 34px rgba(0,0,0,0.18);
            background: rgba(255, 255, 255, 0.45);
        }
        .hero-carousel .carousel-item img {
            height: 340px;
            width: 100%;
            object-fit: contain;
            padding: 1.25rem;
        }
        .hero-carousel .carousel-indicators [data-bs-target] {
            background-color: var(--brand);
        }
        .hero-carousel .carousel-caption {
            left: 50%;
            right: auto;
            transform: translateX(-50%);
            bottom: 16px;
            width: auto;
            display: inline-block;
            background: rgba(26, 26, 26, 0.6);
            border-radius: 30px;
            padding: 0.35rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 500;
        }

        /* Section heading */
        .section-title {
            font-weight: 700;
        }
        .section-title .underline {
            display: block;
            width: 60px;
            height: 4px;
            background: var(--brand);
            border-radius: 4px;
            margin-top: 6px;
        }

        .view-all {
            color: var(--brand);
            text-decoration: none;
            font-weight: 500;
        }
        .view-all:hover { color: var(--brand-dark); }

        /* Feature strip */
        .feature-strip {
            background: var(--pink-soft);
            border-radius: 20px;
        }
        .feature-box .icon {
            font-size: 2rem;
        }
        .feature-box h6 { font-weight: 600; margin-top: 0.5rem; }
        .feature-box p { font-size: 0.82rem; color: #7a7a7a; }

        /* Food store cards */
        .store-card {
            border: 1px solid #f0d0d4;
            border-radius: 18px;
            overflow: hidden;
            background: #fff;
            transition: 0.3s;
            height: 100%;
            display: block;
            text-decoration: none;
            color: inherit;
        }
        .store-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 14px 28px rgba(226, 55, 68, 0.16);
            border-color: var(--brand);
        }
        .store-img-wrap {
            background: var(--pink-soft);
            height: 160px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .store-img {
            max-height: 130px;
            max-width: 80%;
            object-fit: contain;
        }
        .store-body { padding: 1rem 1.1rem 1.2rem; }
        .store-name { font-weight: 600; font-size: 1.05rem; margin-bottom: 0.1rem; }
        .store-cuisine { font-size: 0.8rem; color: #7a7a7a; margin-bottom: 0.7rem; }
        .store-meta {
            font-size: 0.8rem;
            color: #555;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .rating-badge {
            background: var(--pink-soft);
            color: var(--brand);
            font-weight: 600;
            border-radius: 8px;
            padding: 0.15rem 0.5rem;
        }

        /* Who We Are */
        .about-img {
            width: 100%;
            border-radius: 20px;
            object-fit: cover;
            box-shadow: 0 14px 30px rgba(0,0,0,0.12);
        }
        .about-list { list-style: none; padding-left: 0; }
        .about-list li { margin-bottom: 0.6rem; font-size: 0.92rem; }
        .about-list li::before { content: '✓'; color: var(--brand); font-weight: 700; margin-right: 0.5rem; }

        /* Auth modals */
        .auth-modal .modal-content {
            border: none;
            border-radius: 18px;
            overflow: hidden;
        }
        .auth-header {
            background: linear-gradient(120deg, #fde2e7 0%, #f9c4cd 100%);
            text-align: center;
            padding: 1.75rem 1.5rem 1.25rem;
            position: relative;
        }
        .auth-header img { height: 56px; }
        .auth-header h5 { font-weight: 700; margin-top: 0.75rem; margin-bottom: 0; }
        .auth-header p { font-size: 0.85rem; color: #6b4a4f; margin: 0; }
        .auth-body { padding: 1.5rem; }
        .auth-body .form-label { font-weight: 500; font-size: 0.85rem; }
        .auth-body .form-control {
            border-radius: 10px;
            padding: 0.6rem 0.9rem;
        }
        .auth-body .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 0.2rem rgba(226, 55, 68, 0.15);
        }
        .code-hint { font-size: 0.8rem; color: #7a7a7a; }
        .auth-body .input-group-text {
            background: var(--pink-soft);
            border-color: #dee2e6;
            font-weight: 600;
            color: #1a1a1a;
        }
        .field-err { display: none; color: var(--brand); font-size: 0.78rem; margin-top: 0.3rem; }
        .btn-auth {
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.65rem;
            font-weight: 600;
            width: 100%;
            transition: 0.25s;
        }
        .btn-auth:hover { background: var(--brand-dark); color: #fff; }
        .btn-link-brand {
            background: none;
            border: none;
            color: var(--brand);
            font-size: 0.82rem;
            font-weight: 500;
            padding: 0;
        }
        .btn-link-brand:hover { text-decoration: underline; }
        .auth-switch { font-size: 0.85rem; text-align: center; margin-top: 1rem; }
        .auth-switch a { color: var(--brand); text-decoration: none; font-weight: 600; cursor: pointer; }
        .auth-switch a:hover { text-decoration: underline; }

        /* Footer */
        footer {
            background: #1a1a1a;
            color: #ddd;
        }
        footer a { color: #ddd; text-decoration: none; }
        footer a:hover { color: var(--brand); }
        footer h6 { font-weight: 600; margin-bottom: 1rem; color: #fff; }
        .footer-logo { height: 64px; }
        .footer-text { font-size: 0.85rem; color: #aaa; }
        footer ul { list-style: none; padding-left: 0; }
        footer ul li { margin-bottom: 0.5rem; font-size: 0.88rem; }
        .footer-divider { border-color: #333; }
        .social a {
            display: inline-flex;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #2a2a2a;
            align-items: center;
            justify-content: center;
            margin-right: 0.4rem;
            font-size: 0.78rem;
        }
        .social a:hover { background: var(--brand); color: #fff; }

        /* Cart button + badge */
        .btn-cart {
            border: 1px solid var(--brand);
            background: #fff;
            border-radius: 8px;
            font-size: 1.1rem;
            line-height: 1;
            padding: 0.35rem 0.6rem;
            position: relative;
        }
        .btn-cart:hover { background: var(--pink-soft); }
        .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--brand);
            color: #fff;
            font-size: 0.68rem;
            font-weight: 700;
            min-width: 20px;
            height: 20px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
        }

        /* Cart drawer */
        .cart-item { display: flex; gap: 0.75rem; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid #f0d0d4; }
        .cart-item img { width: 52px; height: 52px; object-fit: cover; border-radius: 10px; }
        .cart-item-name { font-weight: 600; font-size: 0.9rem; }
        .cart-item-price { color: var(--brand); font-weight: 600; font-size: 0.85rem; }
        .qty-box { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 0.3rem; }
        .qty-box button {
            border: 1px solid #e0a4ac;
            background: #fff;
            width: 26px;
            height: 26px;
            border-radius: 6px;
            line-height: 1;
            font-weight: 700;
            color: #1a1a1a;
        }
        .qty-box button:hover { background: var(--pink-soft); }
        .cart-remove { background: none; border: none; color: #7a7a7a; font-size: 0.78rem; }
        .cart-remove:hover { color: var(--brand); text-decoration: underline; }
        .cart-empty { text-align: center; color: #7a7a7a; padding: 3rem 1rem; }
        .cart-footer { border-top: 1px solid #f0d0d4; padding-top: 1rem; margin-top: 0.5rem; }
        .btn-checkout {
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.6rem;
            font-weight: 600;
        }
        .btn-checkout:hover { background: var(--brand-dark); color: #fff; }
    </style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="/">
            <img src="<%= images.logo %>" alt="FoodHub"
                 onerror="this.style.display='none';document.getElementById('brandText').style.display='inline';">
            <span id="brandText" style="display:none;">food<span class="brand-red">hub</span></span>
        </a>

        <div class="d-none d-lg-flex flex-grow-1 justify-content-center">
            <a href="/" class="nav-link-custom">Home</a>
            <a href="/stores" class="nav-link-custom">Stores</a>
        </div>

        <div class="d-flex align-items-center">
            <button type="button" class="btn btn-cart position-relative me-2" id="cartButton" aria-label="Open cart">
                &#128722;<span class="cart-badge" id="cartBadge">0</span>
            </button>

            <!-- Logged-out: Login / Sign Up -->
            <div id="authButtons" class="d-flex">
                <button type="button" class="btn btn-login me-2" data-bs-toggle="modal" data-bs-target="#loginModal">Login</button>
                <button type="button" class="btn btn-signup" data-bs-toggle="modal" data-bs-target="#signupModal">Sign Up</button>
            </div>

            <!-- Logged-in: avatar + name dropdown -->
            <div id="userMenu" class="dropdown d-none">
                <button class="btn btn-user dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="user-avatar" id="userInitial">U</span>
                    <span id="userName">User</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li><a class="dropdown-item" href="#">My Profile</a></li>
                    <li><a class="dropdown-item" href="/menu">My Orders</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="#" id="logoutBtn">Logout</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="container mt-4">
    <div class="hero p-4 p-md-5">
        <div class="row align-items-center hero-content">

            <div class="col-md-6">
                <h1>
                    Order Your<br>
                    Favourite Food<br>
                    <span class="brand-red">Fast &amp; Easy</span>
                </h1>

                <p class="tagline mt-3 mb-4">
                    Freshly prepared meals from your favourite campus stores.
                    Order ahead, skip the queue, and collect when ready.
                </p>

                <div>
                    <a href="/stores" class="btn btn-order">Browse Stores &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 mt-4 mt-md-0">
                <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
                    </div>
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="/images/pizza.png" alt="Cheese Pizza">
                            <div class="carousel-caption">Wood-fired Pizza 🍕</div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/burger.png" alt="Hamburger">
                            <div class="carousel-caption">Juicy Burgers 🍔</div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/mala.png" alt="Mala Xiang Guo">
                            <div class="carousel-caption">Spicy Mala 🌶️</div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/pasta.png" alt="Creamy Pasta">
                            <div class="carousel-caption">Creamy Pasta 🍝</div>
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Feature Strip (moved up, right under the hero) -->
<section class="container pt-5">
    <div class="feature-strip p-4">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">🥡</div>
                <h6>Quick Pickup</h6>
                <p>Order ahead and skip the queue.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">🥗</div>
                <h6>Fresh Ingredients</h6>
                <p>Sourced fresh and cooked to order.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">💳</div>
                <h6>Easy Payment</h6>
                <p>Secure checkout with multiple options.</p>
            </div>
            <div class="col-6 col-md-3 feature-box">
                <div class="icon">⭐</div>
                <h6>Top Rated</h6>
                <p>Loved by thousands of happy customers.</p>
            </div>
        </div>
    </div>
</section>

<!-- Food Stores -->
<section class="container py-5" id="stores">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">
            Food Stores
            <span class="underline"></span>
        </h2>
        <a href="/stores" class="view-all">View All &rarr;</a>
    </div>

    <div class="row g-3">

        <% foodStores.slice(0, 4).forEach(store => { %>

        <div class="col-6 col-md-3">

            <a href="/menu" class="store-card">

                <div class="store-img-wrap">
                    <img src="<%= store.image %>" class="store-img" alt="<%= store.name %>">
                </div>

                <div class="store-body">
                    <div class="store-name"><%= store.name %></div>
                    <div class="store-cuisine"><%= store.cuisine %></div>
                    <div class="store-meta">
                        <span class="rating-badge">⭐ <%= store.rating %></span>
                        <span>🕒 Ready in <%= store.prepTime %></span>
                    </div>
                </div>

            </a>

        </div>

        <% }) %>

    </div>
</section>

<!-- Who We Are -->
<section class="container py-5" id="about">
    <div class="row align-items-center g-4">
        <div class="col-md-6">
            <img src="<%= images.hero %>" class="about-img" alt="About FoodHub">
        </div>
        <div class="col-md-6">
            <h2 class="section-title mb-3">
                Who We Are
                <span class="underline"></span>
            </h2>
            <p class="text-muted">
                FoodHub is a campus food-ordering platform built for students, by students.
                We bring together your favourite canteen stalls and nearby stores in one place,
                so you can grab a quick meal between classes without the queue.
            </p>
            <ul class="about-list">
                <li>One app for every store on and around campus.</li>
                <li>Student-friendly prices and no hidden fees.</li>
                <li>Quick phone sign-in — no passwords to remember.</li>
                <li>Order ahead and collect when it's ready.</li>
            </ul>
            <a href="/menu" class="btn btn-order mt-2">Start Ordering &rarr;</a>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="pt-5 pb-4">
    <div class="container">
        <div class="row gy-4">

            <div class="col-md-4">
                <a href="/" class="d-inline-block mb-3">
                    <img src="<%= images.logo %>" alt="FoodHub" class="footer-logo"
                         onerror="this.style.display='none';document.getElementById('footerBrandText').style.display='inline';">
                    <span id="footerBrandText" class="fw-bold fs-4" style="display:none;">food<span class="brand-red">hub</span></span>
                </a>
                <p class="footer-text">
                    Tasty meals from your favourite campus stores.
                    Built for students, priced for students.
                </p>
                <div class="social mt-3">
                    <a href="#" aria-label="Facebook">f</a>
                    <a href="#" aria-label="Instagram">ig</a>
                    <a href="#" aria-label="TikTok">tt</a>
                    <a href="#" aria-label="Telegram">tg</a>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <h6>Explore</h6>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/stores">Stores</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="/checkout">Checkout</a></li>
                </ul>
            </div>

            <div class="col-6 col-md-3">
                <h6>Contact</h6>
                <ul>
                    <li>📞 +65 9123 4567</li>
                    <li>✉️ hello@foodhub.sg</li>
                    <li>📍 Campus Hub, Singapore</li>
                </ul>
            </div>

            <div class="col-md-3">
                <h6>Opening Hours</h6>
                <ul>
                    <li>Mon – Fri: 9am – 9pm</li>
                    <li>Sat – Sun: 10am – 8pm</li>
                </ul>
            </div>

        </div>

        <hr class="footer-divider my-4">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
            <span class="footer-text mb-2 mb-md-0">&copy; 2026 FoodHub. All rights reserved.</span>
            <span class="footer-text">Made for students 🎓</span>
        </div>
    </div>
</footer>

<!-- Login Modal -->
<div class="modal fade auth-modal" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="auth-header">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img src="<%= images.logo %>" alt="FoodHub">
                <h5>Welcome Back</h5>
                <p>Log in with your phone number</p>
            </div>

            <div class="auth-body">

                <!-- Step 1: phone number -->
                <div id="loginStep1">
                    <div class="mb-3">
                        <label class="form-label">Phone number</label>
                        <div class="input-group">
                            <span class="input-group-text">+65</span>
                            <input type="tel" id="loginPhone" class="form-control" placeholder="9123 4567" autocomplete="tel" maxlength="9">
                        </div>
                        <div id="loginPhoneErr" class="field-err">Enter a valid 8-digit Singapore number (starts with 6, 8 or 9).</div>
                    </div>
                    <button type="button" id="loginSendBtn" class="btn-auth">Send Security Code</button>
                </div>

                <!-- Step 2: security code -->
                <div id="loginStep2" style="display:none;">
                    <p class="code-hint mb-3">
                        We sent a 6-digit code to <strong id="loginSentTo"></strong>.
                        <span class="text-muted">(Demo: enter any 6 digits)</span>
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Security code</label>
                        <input type="text" inputmode="numeric" maxlength="6" id="loginCode" class="form-control" placeholder="● ● ● ● ● ●">
                        <div id="loginCodeErr" class="field-err">Enter the 6-digit code.</div>
                    </div>
                    <button type="button" id="loginVerifyBtn" class="btn-auth">Verify &amp; Login</button>
                    <div class="text-center mt-2">
                        <button type="button" class="btn-link-brand" id="loginResend">Use a different number</button>
                    </div>
                </div>

                <p class="auth-switch">
                    Don't have an account?
                    <a data-bs-toggle="modal" data-bs-target="#signupModal" data-bs-dismiss="modal">Sign Up</a>
                </p>
            </div>

        </div>
    </div>
</div>

<!-- Sign Up Modal -->
