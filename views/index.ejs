<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Food Ordering System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-danger shadow">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            🍔 FoodHub
        </a>

        <div>
            <a href="/" class="btn btn-outline-light me-2">Home</a>
            <a href="/menu" class="btn btn-light">Menu</a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="container py-5">

    <div class="row align-items-center">

        <div class="col-md-6">
            <h1 class="display-4 fw-bold">
                Order Your Favourite Meals
            </h1>

            <p class="lead text-muted">
                Browse delicious food, place orders, track delivery status,
                and leave reviews all in one place.
            </p>

            <a href="/menu" class="btn btn-danger btn-lg">
                Browse Menu
            </a>
        </div>

        <div class="col-md-6 text-center">
            <img
                src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=900"
                class="img-fluid rounded shadow"
                alt="Food">
        </div>

    </div>

</section>

<!-- Features -->
<section class="container pb-5">

    <h2 class="text-center mb-4">
        System Features
    </h2>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>🍔 Menu</h4>
                    <p>Browse available food items.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>🔐 Login</h4>
                    <p>User authentication system.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h4>📦 Tracking</h4>
                    <p>Track order preparation status.</p>
                </div>
            </div>
        </div>

    </div>

</section>

</body>
</html>